DATABASE_URL=postgresql+asyncpg://user:password@localhost/car_wash_db
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=car_wash_nosql
DEBUG=True
SECRET_KEY=your_secret_key_here_change_in_production
ENVIRONMENT=development

# JWT Settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Bootstrap: initial superadmin (created on first startup if no admin exists)
# Remove these vars after the first run, or leave them — they are ignored once an admin exists
INITIAL_ADMIN_EMAIL=admin@lavadero.com
INITIAL_ADMIN_PASSWORD=changeme123
INITIAL_ADMIN_NAME=Admin
