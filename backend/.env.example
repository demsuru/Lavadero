# DATABASE - PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/car_wash_db

# MONGODB - NoSQL for flexible vehicle schema
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=car_wash_nosql

# DEBUG & ENVIRONMENT
DEBUG=True
ENVIRONMENT=development

# SECRET KEY - Change in production!
SECRET_KEY=your_secret_key_here_change_in_production

# JWT SETTINGS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# BOOTSTRAP - Initial superadmin (created on first startup if no admin exists)
# After first run, these can be removed or changed — they're ignored once an admin is created
INITIAL_ADMIN_EMAIL=admin@lavadero.com
INITIAL_ADMIN_PASSWORD=admin123
INITIAL_ADMIN_NAME=Admin
